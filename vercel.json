{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd fractal-lab/frontend && npm ci && npm run build",
  "outputDirectory": "fractal-lab/frontend/dist",
  "installCommand": "cd fractal-lab/frontend && npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
